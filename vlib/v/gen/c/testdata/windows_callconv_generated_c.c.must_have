#define VCALLCONV(name) __##name
#define VCALLCONV(name) __attribute__((name))
typedef int (VCALLCONV(stdcall) *VectoredExceptionHandler)(ExceptionPointers*);
VV_LOC int VCALLCONV(stdcall) builtin__unhandled_exception_handler(ExceptionPointers* e);
AddVectoredExceptionHandler(1, builtin__unhandled_exception_handler);
