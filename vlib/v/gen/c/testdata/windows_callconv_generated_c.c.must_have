#define VCALLCONV(name) __##name
#define VCALLCONV(name) __attribute__((name))
#define C__LONG LONG
typedef C__LONG (VCALLCONV(stdcall) *TopLevelExceptionFilter)(ExceptionPointers*);
VV_LOC C__LONG VCALLCONV(stdcall) builtin__unhandled_exception_handler(ExceptionPointers* e);
SetUnhandledExceptionFilter(builtin__unhandled_exception_handler);
