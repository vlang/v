// vtest vflags: -autofree

fn mark(s string) string {
	return s + '!'
}

fn main() {
	suffix := 'tcc/lib/libgc.dylib'
	flags := ['"thirdparty/tcc/lib/libgc.dylib"', 'other'].map(if it.ends_with(suffix + '"')
		&& it.starts_with('"') {
		'"/tmp/libgc.dylib"'
	} else {
		it
	})
	println(flags)
	branch_flags := ['a', 'b'].map(if it == 'a' {
		mark(it + 'x')
	} else {
		it
	})
	println(branch_flags)
	anon_flags := ['ax', 'b'].map(fn (it string) string {
		suffix := 'x'
		if it.ends_with(suffix + '') {
			return mark(it)
		}
		return it
	})
	println(anon_flags)
	// This regression only needs the generated C to compile.
	exit(0)
}
