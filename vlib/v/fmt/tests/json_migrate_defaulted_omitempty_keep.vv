import json

// A defaulted `@[omitempty]` field decodes differently between the modules: json2 skips a
// present empty value and keeps the field default, while legacy json assigns the present
// value and only uses the default when the key is absent — so `{"name":""}` decodes to the
// default `'anon'` under json2 vs `''` under legacy json. A payload/target with such a field
// is left on legacy json (a plain omitempty string/number without a default still migrates).
struct Settings {
	name string = 'anon' @[omitempty]
}

fn from_json(s string) !Settings {
	return json.decode(Settings, s)
}
