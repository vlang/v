import json
import time

// An anonymous struct payload (`struct { t time.Time }{ ... }`) has no file-local
// StructDecl for the scan to catch, so type_needs_legacy_json recurses into the struct
// type's own fields. The time.Time field serialises as a Unix number in legacy json but
// an RFC3339 string in json2, so the file is left unmigrated.
fn encode_anon() string {
	return json.encode(struct {
		t time.Time
	}{
		t: time.now()
	})
}
