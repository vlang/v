import json

// A sum type variant can itself be a legacy-sensitive payload: legacy json encodes a
// `rune` variant as a string and a non-finite float variant as `null`, where json2
// emits a number / raw `nan`/`inf`. type_needs_legacy_json recurses into the variants,
// so a payload or decode target containing such a sum type keeps the file on `json`.
type Glyph = int | rune

type Number = f64 | string

struct Box {
	g Glyph
}

fn to_json(b Box) string {
	return json.encode(b)
}

fn parse(s string) !Number {
	return json.decode(Number, s)
}
