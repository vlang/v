import json

struct User {
	name string
}

// A C-style `for` initializer (`for json2 := 0; ...`) declares a loop variable that
// shadows the module qualifier the migration would use for calls in the loop body.
// The file's json usage is therefore left unmigrated.
fn to_json(u User) string {
	for json2 := 0; json2 < 1; json2++ {
		return json.encode(u)
	}
	return ''
}

fn main() {
	println(to_json(User{ name: 'bob' }))
}
