import json

type Choice = int | string

struct Inner {
	x int
}

// Legacy json drops an `@[omitempty]` field that equals the type default, but json2's
// check_not_empty only guards string / number / array / map / option / pointer values and
// always emits bool / struct / sum type / enum fields. So a payload with `@[omitempty]` on
// such a field would start emitting fields legacy json omitted — the file is left
// unmigrated. (An `@[omitempty]` string/int/array field migrates, since json2 guards it
// the same way.)
struct Payload {
	active bool   @[omitempty]
	inner  Inner  @[omitempty]
	choice Choice @[omitempty]
	name   string @[omitempty]
}

fn to_json(p Payload) string {
	return json.encode(p)
}
