import json

struct User {
	name string
}

// `json.encode_pretty` in a loop header (condition/iterable/C-style cond+inc) is not
// reachable through the walker (For*.children() yields only the body), so the
// unmigratable scan sub-walks the loop headers. The file is left unmigrated because
// encode_pretty cannot be reproduced by json2.
fn to_json(u User) string {
	for json.encode_pretty(u) != '' {
		break
	}
	return json.encode(u)
}

fn main() {
	println(to_json(User{ name: 'bob' }))
}
