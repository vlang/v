import json

struct User {
	name string
}

struct App {
	name string
}

fn (a App) log(s string) {
	println(s)
}

// A comptime method call (`a.$method(...)`) prints its arguments via comptime_call, but
// ComptimeCall.args are outside Node.children(), so the unmigratable scan sub-walks
// them. The argument here is a json.encode_pretty call that json2 cannot reproduce, so
// the file is left unmigrated.
fn run(u User) {
	a := App{}
	$for method in App.methods {
		a.$method(json.encode_pretty(u))
	}
}
