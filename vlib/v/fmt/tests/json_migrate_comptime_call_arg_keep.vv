import json

struct User {
	name string
}

struct App {
	name string
}

fn (a App) log(s string) {
	println(s)
}

// comptime_call prints a comptime method call's arguments verbatim via call_arg_spread_str
// (arg.str()), not through call_expr, so a json call in an argument can never be rewritten.
// Even a normally-migratable `json.encode(u)` must therefore keep the file unmigrated —
// otherwise the import would become `json2` while the argument still read `json.encode(u)`.
fn run(u User) {
	a := App{}
	$for method in App.methods {
		a.$method(json.encode(u))
	}
}
