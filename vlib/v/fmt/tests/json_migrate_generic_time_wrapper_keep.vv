import json
import time

struct Box[T] {
	val T
}

// A `time.Time` reaches the JSON only through a generic instantiation's concrete
// type argument (`Box[time.Time]`); the concrete field's final symbol is `Box`, so
// type_mentions_time inspects GenericInst.concrete_types. Such a payload keeps the
// file unmigrated.
struct User {
	box   Box[time.Time]
	other []Box[time.Time]
}

fn to_json(u User) string {
	return json.encode(u)
}
