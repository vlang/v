import json

// A sum type with an option variant (`?int`) serialises differently: legacy json emits a
// `none` value as `{}`, while json2 emits an empty array slot (`[1,,3]`, invalid JSON).
// The option flag is stripped by final_sym, so type_needs_legacy_json checks it up front
// and a payload containing such a sum type keeps the file on legacy json.
type Elem = int | ?int

struct Box {
	e Elem
}

fn to_json(b Box) string {
	return json.encode(b)
}
