import json

struct User {
	name string
}

// An `or { ... }` block attached to a non-call expression (an identifier here, an index
// expression below) is a separate field that Node.children() does not expose, unlike a
// CallExpr's or-block. Both hold a json.encode_pretty call that json2 cannot reproduce,
// so the file is left unmigrated.
fn from_opt(opt ?string, u User) string {
	return opt or { json.encode_pretty(u) }
}

fn from_map(m map[string]string, u User) string {
	return m['k'] or { json.encode_pretty(u) }
}
