import json

struct User {
	name string
}

fn parts(s string) []string {
	return [s]
}

// The spread expression of `[...a, b]` is stored on ArrayInit.update_expr, outside
// Node.children(), so the unmigratable scan sub-walks it. This file spreads a
// json.encode_pretty result, so it is left unmigrated.
fn build(u User) []string {
	_ := json.encode(u)
	return [...parts(json.encode_pretty(u)), 'x']
}
