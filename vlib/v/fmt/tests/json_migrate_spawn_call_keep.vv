import json

struct User {
	name string
}

fn worker(s string) {
}

// A spawned/`go` call is stored on SpawnExpr.call_expr / GoExpr.call_expr, which are
// outside Node.children(), so the unmigratable scan sub-walks them. This file uses
// json.encode_pretty inside a spawned call, so it is left unmigrated.
fn work(u User) {
	spawn json.encode_pretty(u)
	spawn worker(json.encode_pretty(u))
	go worker(json.encode_pretty(u))
	_ := json.encode(u)
}
