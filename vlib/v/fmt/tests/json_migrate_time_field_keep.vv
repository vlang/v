import json
import time

// A `time.Time` field encodes as a unix number under the legacy `json` module but
// as an RFC3339 string under `json2`, and json2 has no option to restore the unix
// form. vfmt has no type info for the encode payload, so a file that declares a
// struct with a `time.Time` field is conservatively left unmigrated.
struct User {
	name     string
	reg_date time.Time
}

fn to_json(u User) string {
	return json.encode(u)
}

fn from_json(s string) !User {
	return json.decode(User, s)
}

fn main() {
	println(to_json(User{ name: 'bob', reg_date: time.now() }))
}
