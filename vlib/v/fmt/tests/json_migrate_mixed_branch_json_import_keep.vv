module main

import json as old

// A top-level json import with a distinct local name plus a branch-local json import
// would both normalize to `import json2`; a branch import that is emitted before the
// top-level one goes to branch_processed_imports, not the global list, so the checker
// would then see a duplicate `json2`. The file is left unmigrated.
$if linux {
	import json
}

fn dump_json(x int) string {
	return json.encode(x)
}

fn main() {
	println(dump_json(1))
}
