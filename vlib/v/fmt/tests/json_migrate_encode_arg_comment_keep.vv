import json

struct User {
	name string
}

// A trailing line comment on the encode argument cannot survive the synthetic
// `escape_unicode: true` option that migration appends (call_args emits the comment and a
// newline, so the option would land after it as a stray leading comma). The call is left
// unmigrated so the file stays valid.
fn to_json(u User) string {
	return json.encode(u // keep me
	 )
}
