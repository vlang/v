import json
import time

// A spread-only map literal (`{ ...times }`) has no explicit values; the spread lives on
// MapInit.update_expr, outside `vals`, and the literal's typ/key/value are usually zero at
// fmt time. Here it spreads a `map[string]time.Time`, whose values serialise as Unix numbers
// in legacy json but RFC3339 strings in json2, so the safety check inspects update_expr and
// leaves the file on legacy json. (A spread of a safe value type like `map[string]int` still
// migrates.)
fn to_json(times map[string]time.Time) string {
	return json.encode({
		...times
	})
}
