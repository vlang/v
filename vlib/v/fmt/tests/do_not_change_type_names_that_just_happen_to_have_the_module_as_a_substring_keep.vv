module gzip

import compress.gzip
import hash.crc32

pub struct GzipHeader {
pub mut:
	length           int = 10
	operating_system u8
}

pub fn compress(data []u8) ![]u8 {
	compressed := gzip.compress(data)!
	return compressed
}

pub fn decompress(data []u8) ![]u8 {
	header := GzipHeader{}
	decompressed := gzip.decompress(data)!
	return decompressed
}
