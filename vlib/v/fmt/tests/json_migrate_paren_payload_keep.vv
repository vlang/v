import json
import time

// A legacy-sensitive payload wrapped in parentheses is a ParExpr at the top level;
// payload_expr_needs_legacy_json unwraps it so the inner typed literal is still inspected.
// Without the unwrap, vfmt would migrate these and silently change the encoding of the
// wrapped rune / time.Time payload. (A parenthesised safe payload like `(int(5))` still
// migrates, since the unwrapped literal is not legacy-sensitive.)
fn encode_rune() string {
	return json.encode((rune(233)))
}

fn encode_anon() string {
	return json.encode((struct {
		t time.Time
	}{
		t: time.now()
	}))
}
