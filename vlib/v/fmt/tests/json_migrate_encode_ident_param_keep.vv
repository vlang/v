import json
import net.http

// The encode payload here is a plain identifier, not a literal — but a function parameter
// carries a declared type at parse time, so it is resolved and inspected. `http.Cookie` is
// an imported type (a placeholder at fmt time) that contains a `time.Time` field vfmt cannot
// see, so the file is kept on legacy json rather than silently changing the JSON contract.
fn to_json(c http.Cookie) string {
	return json.encode(c)
}
