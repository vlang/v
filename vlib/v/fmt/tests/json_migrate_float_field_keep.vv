import json

// Legacy json emits `null` for NaN/±Inf floats while json2 emits `nan`/`inf`, so a
// payload with f32/f64 fields is conservatively left unmigrated (vfmt cannot know the
// runtime value, and only non-finite values differ).
struct Stats {
	value   f64
	ratio   f32
	samples []f64
}

fn to_json(s Stats) string {
	return json.encode(s)
}
