import json
import time

// When the JSON payload itself is `time.Time` (or contains it), json2 emits an
// RFC3339 string via Time.to_json while legacy json does not use that hook for the
// root value. The decode target is a known TypeNode, and an encode struct-literal /
// cast argument has a known type, so such calls keep the file on `json`. (A runtime
// encode value like `json.encode(time.utc())` has no type at fmt time and is a known
// limitation.)
fn decode_time(s string) !time.Time {
	return json.decode(time.Time, s)
}

fn decode_times(s string) ![]time.Time {
	return json.decode([]time.Time, s)
}

fn encode_time() string {
	return json.encode(time.Time{})
}
