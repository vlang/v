import json
import time

// A field whose type is a local alias of `time.Time` still serialises as a unix
// number under legacy json but an RFC3339 string under json2. The time-field guard
// unaliases the field type (final_sym), so such files are left unmigrated too.
type MyTime = time.Time

struct User {
	name     string
	reg_date MyTime
}

fn to_json(u User) string {
	return json.encode(u)
}

fn main() {
	println(to_json(User{ name: 'bob', reg_date: time.now() }))
}
