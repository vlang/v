import json { decode }
import time

// With a selective import the parser does not know `decode` is `json.decode` until after
// it has parsed the arguments, so the target type arrives as a plain name expression
// (`time.Time`), not a resolved TypeNode. decode_target_expr_needs_legacy_json resolves it
// and finds time.Time, whose legacy root JSON contract (a Unix number) differs from json2's
// RFC3339 string — so the file is left unmigrated. (A safe target like a plain struct still
// migrates, since the resolved type is not legacy-sensitive.)
fn decode_time(s string) !time.Time {
	return decode(time.Time, s)
}
