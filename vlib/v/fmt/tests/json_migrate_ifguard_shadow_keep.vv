import json

struct User {
	name string
}

fn maybe() ?int {
	return 5
}

// An `if json2 := opt() { ... }` guard introduces a local named `json2` for the
// branch, shadowing the module qualifier the migration would use for calls inside
// it. The file's json usage is therefore left unmigrated.
fn to_json(u User) string {
	if json2 := maybe() {
		_ := json2
		return json.encode(u)
	}
	return ''
}

fn main() {
	println(to_json(User{ name: 'bob' }))
}
