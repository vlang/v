import json

// Under `-enable-globals`, a `__global json2 ...` declaration is an existing identifier
// that would shadow the migrated qualifier: after rewriting `json.encode` to
// `json2.encode`, the selector would resolve against the global value instead of the
// imported module, so previously valid code stops compiling. The file is left unmigrated.
__global json2 = 42

struct User {
	name string
}

fn to_json(u User) string {
	return json.encode(u)
}
