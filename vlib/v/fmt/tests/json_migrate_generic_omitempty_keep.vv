import json

// A generic wrapper's `@[omitempty]` field only becomes legacy-sensitive once its type
// parameter is instantiated: `Box[bool]` omits the default `false` under legacy json but
// json2 always emits it. The concrete-type list of the instantiation only shows `bool`, not
// the parent field's attribute, so the guard recurses into the base struct's fields; a
// generic-parameter field (`val T`) resolves to kind `.any`, treated as omitempty-sensitive
// because its concrete type is unknown at fmt time. The file is left unmigrated.
struct Box[T] {
	val T @[omitempty]
}

fn to_json() string {
	return json.encode(Box[bool]{})
}
