import json

struct User {
	name string
}

// A lambda parameter named like the migrated qualifier (`|json2| ...`) shadows the
// module for the lambda body, so a rewritten `json2.encode(...)` would bind to the
// parameter. The file's json usage is left unmigrated.
fn to_json(u User) []string {
	return [1].map(|json2| json.encode(u))
}

fn main() {
	println(to_json(User{ name: 'bob' }))
}
