import json

struct Custom {
	a int
}

// A payload type that implements a json2 custom hook (`to_json`/`json_str` for
// encode, `from_json_*` for decode) makes json2 dispatch to that hook, emitting
// different bytes than the legacy field-based json path. The file is left
// unmigrated whenever such a hook method is declared.
fn (c Custom) to_json() string {
	return '"custom"'
}

fn to_json_str(c Custom) string {
	return json.encode(c)
}

fn main() {
	println(to_json_str(Custom{ a: 1 }))
}
