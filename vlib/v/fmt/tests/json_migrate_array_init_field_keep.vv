import json

struct User {
	name string
}

// The len:/cap:/init: expressions of an array initializer are stored on
// ArrayInit.len_expr/cap_expr/init_expr, which are outside Node.children(), so the
// unmigratable scan sub-walks them. This file uses json.encode_pretty in an `init:`
// field, so it is left unmigrated.
fn build(u User) []string {
	_ := json.encode(u)
	return []string{len: 1, init: json.encode_pretty(u)}
}
