import json

// A `@[raw]` field keeps the normalized JSON subtree under the legacy `json` module
// (cJSON's unformatted printer) but the raw source slice under `json2`, and json2
// has no option to restore the normalized form. A file that declares a struct with
// a `@[raw]` field is therefore left unmigrated.
struct Color {
	space string
	point string @[raw]
}

fn parse(s string) !Color {
	return json.decode(Color, s)
}

fn main() {
	c := parse('{"space": "YCbCr", "point": {"Y": 123}}')!
	println(c.point)
}
