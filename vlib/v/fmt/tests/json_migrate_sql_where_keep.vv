import json
import db.sqlite

struct User {
	id   int @[primary; sql: serial]
	name string
}

// A json.encode_pretty call inside the SQL DSL lives on SqlExpr.where_expr, outside
// Node.children(), so the unmigratable scan sub-walks the sql query's exprs. This
// file is left unmigrated.
fn query(db sqlite.DB, u User) []User {
	users := sql db {
		select from User where name == json.encode_pretty(u)
	} or { [] }
	_ := json.encode(u)
	return users
}
